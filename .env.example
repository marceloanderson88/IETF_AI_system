# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # só no servidor / ingestão. NUNCA no client.
SUPABASE_DB_URL=                  # conexão direta p/ migrations e ingestão

# ─── Embeddings (Gemini) — MESMO modelo/dim em app e ingestion (invariante) ──
# text-embedding-004 → 768 dimensões. Trocar = re-embedar o corpus + alterar a coluna.
EMBEDDINGS_PROVIDER=gemini
EMBEDDINGS_MODEL=text-embedding-004
EMBEDDINGS_DIM=768

# ─── LLM (geração — Gemini) ──────────────────────────────────────────────────
GEMINI_API_KEY=
LLM_MODEL_QUALITY=gemini-2.5-flash       # justificativa, rascunho de e-mail
LLM_MODEL_CHEAP=gemini-2.0-flash         # classificação de delta, tarefas baratas

# ─── Entrega ─────────────────────────────────────────────────────────────────
RESEND_API_KEY=                   # opcional no MVP (digest por e-mail)

# ─── Cron (Vercel) ───────────────────────────────────────────────────────────
CRON_SECRET=                      # protege os endpoints /api/cron/*
